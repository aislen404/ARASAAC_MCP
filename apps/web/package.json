{
  "name": "arasaac-social-mcp-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-cs-assets.mjs && next dev",
    "prebuild": "node scripts/sync-cs-assets.mjs",
    "build": "next build",
    "build:clean": "npm run clean && next build",
    "clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true, maxRetries: 10, retryDelay: 200 })\"",
    "prestart": "node scripts/sync-cs-assets.mjs",
    "start": "next start",
    "lint": "eslint src tests eslint.config.mjs next.config.ts playwright.config.ts vitest.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@axe-core/playwright": "4.12.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "typescript": "5.8.2",
    "vitest": "4.1.9"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
